RewriteEngine On
RewriteBase /

# Redireciona /pt, /en, etc para pages/index.php mantendo o idioma na URL
RewriteRule ^(pt|en|es|de|ar)/?$ pages/index.php?lang=$1 [L,QSA]

# Redireciona /pt/converter para pages/converter.php (se existir) ou trata via index
RewriteRule ^(pt|en|es|de|ar)/converter$ pages/converter.php?lang=$1 [L,QSA]

# Remove a necessidade de .php na URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]